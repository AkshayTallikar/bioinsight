# Copy this file to .streamlit/secrets.toml for local dev
# In Streamlit Cloud: paste these as "Secrets" in the app settings UI

# Required: URL of your deployed FastAPI backend (no trailing slash)
BIOINSIGHT_API_URL = "https://bioinsight-backend.onrender.com"

# Optional: NCBI API key (increases ClinVar rate limit from 3 → 10 req/s)
# Get one free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY = ""
